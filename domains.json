{
  "domains": {
    "music": {
      "description": "MusicBrainz creative core — recordings & artists",
      "filter": { "entityType": ["Recording", "Artist"] },
      "bundle_schema": "stage_volumes/schemas/fangorn.mb.creativecore.v4.json",
      "presentation": {
        "types": {
          "Recording": { "icon": "≋", "accent": "#7aa2f7", "singular": "Recording", "plural": "Recordings" },
          "Artist": { "icon": "🎤", "accent": "#f7768e", "singular": "Artist", "plural": "Artists" }
        },
        "fieldLabels": { "byArtist": "By", "durationMs": "Length", "mbid": "MusicBrainz ID" },
        "externalUrl": {
          "Recording": "https://musicbrainz.org/recording/{mbid}",
          "Artist": "https://musicbrainz.org/artist/{mbid}"
        }
      }
    },
    "venues": {
      "description": "Places & events",
      "filter": { "entityType": ["Place", "Event"] },
      "bundle_schema": "stage_volumes/schemas/fangorn.mb.creativecore.v4.json"
    },
    "places": {
      "description": "Local places & events — a searchable directory from Google Places + Eventbrite/Tribe",
      "filter": { "entityType": ["Business", "Event"] },
      "bundle_schema": "stage_volumes/schemas/fangorn.places.localcore.v1.json",
      "role_map": {
        "identity": "placeId",
        "title": "title",
        "subtitle": "primaryType",
        "temporal": null,
        "spatial": "locality",
        "media": "googleMapsUri",
        "tags": ["categories"],
        "measures": ["rating", "userRatingCount"],
        "relations": [],
        "text": ["text", "editorialSummary"]
      },
      "presentation": {
        "types": {
          "Business": { "icon": "🏪", "accent": "#d98a2b", "singular": "Place", "plural": "Places" },
          "Event": { "icon": "🎫", "accent": "#c2562b", "singular": "Event", "plural": "Events" },
          "Organizer": { "icon": "📣", "accent": "#2f7d57", "singular": "Organizer", "plural": "Organizers" }
        },
        "fieldLabels": {
          "editorialSummary": "Summary",
          "userRatingCount": "Reviews",
          "priceLevel": "Price",
          "primaryType": "Type",
          "dateLabel": "When",
          "venueName": "Venue",
          "priceMin": "From",
          "ticketUrl": "Tickets",
          "organizerName": "Hosted by"
        },
        "hideConnections": ["businesses", "localities", "reviewers", "events"],
        "externalUrl": {
          "Business": "{googleMapsUri}",
          "Event": "{ticketUrl}"
        }
      }
    }
  }
}
