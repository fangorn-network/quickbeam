  "presentation": {
    "types": {
      "Artist": {
        "icon": "🎤",
        "accent": "#a78bfa",
        "letter": "A",
        "singular": "Artist",
        "plural": "Artists",
        "definition": "A person, group, or character who creates or performs music, ranging from solo musicians and bands to orchestras and fictional personas."
      },
      "Recording": {
        "icon": "≋",
        "accent": "#34d399",
        "letter": "R",
        "singular": "Recording",
        "plural": "Recordings",
        "definition": "A specific audio (or video) capture of a musical performance, uniquely identified by its duration and ISRC codes."
      },
      "Release": {
        "icon": "💿",
        "accent": "#60a5fa",
        "letter": "Re",
        "singular": "Release",
        "plural": "Releases",
        "definition": "A physical or digital edition of an album, single, or EP — the concrete product that was distributed on a given date by a specific label."
      },
      "ReleaseGroup": {
        "icon": "🗂",
        "accent": "#f472b6",
        "letter": "RG",
        "singular": "Album",
        "plural": "Albums",
        "definition": "The abstract musical work that groups all editions of an album or single together."
      },
      "Work": {
        "icon": "✏",
        "accent": "#fbbf24",
        "letter": "W",
        "singular": "Work",
        "plural": "Works",
        "definition": "The underlying musical or lyrical composition — the song as written, independent of any particular performance or release."
      },
      "Place": {
        "icon": "📌",
        "accent": "#fb923c",
        "letter": "Pl",
        "singular": "Place",
        "plural": "Places",
        "definition": "A physical location associated with music-making: a recording studio, concert hall, venue, or other facility."
      },
      "Event": {
        "icon": "📅",
        "accent": "#f87171",
        "letter": "Ev",
        "singular": "Event",
        "plural": "Events",
        "definition": "A dated live occurrence — a concert, festival, or broadcast — at which artists performed for an audience."
      },
      "Area": {
        "icon": "🌐",
        "accent": "#38bdf8",
        "letter": "Ar",
        "singular": "Area",
        "plural": "Areas",
        "definition": "A geographic region — country, city, or subdivision — that contextualises where artists, events, and recordings originate."
      },
